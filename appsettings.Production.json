{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DetailedErrors": false,
  "RateLimiting": {
    "PermitLimit": 20,
    "WindowSeconds": 60,
    "QueueLimit": 0,
    "StrictPermitLimit": 10,
    "StrictWindowSeconds": 60
  }
}
