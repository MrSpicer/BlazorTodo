@page "/about"

<PageTitle>BlazorTodo - About</PageTitle>

<h1 class="page-title">About</h1>

<div class="about-hero">
	<div class="hero-icon">
		<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
			<path d="M9 11l3 3L22 4"/>
			<path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
		</svg>
	</div>
	<div>
		<h2 class="hero-name">BlazorTodo</h2>
		<p class="hero-tagline">A clean, fast todo app with projects and subtasks</p>
	</div>
</div>

<section class="about-section">
	<h2 class="section-title">Features</h2>
	<div class="feature-grid">
		<div class="feature-card">
			<div class="feature-icon">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<path d="M2 20h20M4 20V10l8-6 8 6v10"/>
				</svg>
			</div>
			<div>
				<h3 class="feature-title">Projects</h3>
				<p class="feature-desc">Organize todos into color-coded projects</p>
			</div>
		</div>
		<div class="feature-card">
			<div class="feature-icon">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<line x1="8" y1="6" x2="21" y2="6"/>
					<line x1="8" y1="12" x2="21" y2="12"/>
					<line x1="8" y1="18" x2="21" y2="18"/>
					<line x1="3" y1="6" x2="3.01" y2="6"/>
					<line x1="3" y1="12" x2="3.01" y2="12"/>
					<line x1="3" y1="18" x2="3.01" y2="18"/>
				</svg>
			</div>
			<div>
				<h3 class="feature-title">Subtasks</h3>
				<p class="feature-desc">Break todos into nested subtasks</p>
			</div>
		</div>
		<div class="feature-card">
			<div class="feature-icon">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
				</svg>
			</div>
			<div>
				<h3 class="feature-title">Priorities</h3>
				<p class="feature-desc">Low, Medium, High, and Emergency levels</p>
			</div>
		</div>
		<div class="feature-card">
			<div class="feature-icon">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
					<polyline points="14 2 14 8 20 8"/>
					<line x1="16" y1="13" x2="8" y2="13"/>
					<line x1="16" y1="17" x2="8" y2="17"/>
					<polyline points="10 9 9 9 8 9"/>
				</svg>
			</div>
			<div>
				<h3 class="feature-title">Notes</h3>
				<p class="feature-desc">Add rich descriptions to any todo</p>
			</div>
		</div>
		<div class="feature-card">
			<div class="feature-icon">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<polyline points="8 17 12 21 16 17"/>
					<line x1="12" y1="12" x2="12" y2="21"/>
					<path d="M20.88 18.09A5 5 0 0018 9h-1.26A8 8 0 103 16.29"/>
				</svg>
			</div>
			<div>
				<h3 class="feature-title">Import / Export</h3>
				<p class="feature-desc">Back up and restore your data as JSON</p>
			</div>
		</div>
		<div class="feature-card">
			<div class="feature-icon">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<polyline points="1 4 1 10 7 10"/>
					<path d="M3.51 15a9 9 0 102.13-9.36L1 10"/>
				</svg>
			</div>
			<div>
				<h3 class="feature-title">Server Sync</h3>
				<p class="feature-desc">Sync data with a remote server endpoint</p>
			</div>
		</div>
		<div class="feature-card">
			<div class="feature-icon">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<line x1="18" y1="20" x2="18" y2="10"/>
					<line x1="12" y1="20" x2="12" y2="4"/>
					<line x1="6" y1="20" x2="6" y2="14"/>
				</svg>
			</div>
			<div>
				<h3 class="feature-title">Statistics</h3>
				<p class="feature-desc">Track completion rates across projects</p>
			</div>
		</div>
	</div>
</section>

<section class="about-section">
	<h2 class="section-title">Tech Stack</h2>
	<div class="tech-list">
		<div class="tech-item">
			<span class="tech-dot"></span>
			<span class="tech-name">Blazor Server</span>
			<span class="tech-desc">— real-time UI with SignalR</span>
		</div>
		<div class="tech-item">
			<span class="tech-dot"></span>
			<span class="tech-name">.NET 10</span>
			<span class="tech-desc">— runtime and framework</span>
		</div>
		<div class="tech-item">
			<span class="tech-dot"></span>
			<span class="tech-name">Blazored.LocalStorage</span>
			<span class="tech-desc">— browser-side persistence</span>
		</div>
	</div>
</section>

