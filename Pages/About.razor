<style>
	.page-title {
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--text-primary);
		margin: 0 0 var(--space-5);
	}

	.about-hero {
		display: flex;
		align-items: center;
		gap: var(--space-4);
		background: var(--surface);
		border: 1px solid var(--border-light);
		border-radius: var(--radius-lg);
		padding: var(--space-5);
		margin-bottom: var(--space-6);
	}

	.hero-icon {
		width: 64px;
		height: 64px;
		border-radius: var(--radius-lg);
		background: var(--primary-50);
		color: var(--primary);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.hero-name {
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--text-primary);
		margin: 0 0 var(--space-1);
	}

	.hero-tagline {
		font-size: 0.9375rem;
		color: var(--text-secondary);
		margin: 0;
	}

	.about-section {
		margin-bottom: var(--space-6);
	}

	.section-title {
		font-size: 1.125rem;
		font-weight: 600;
		color: var(--text-primary);
		margin: 0 0 var(--space-4);
	}

	.feature-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
		gap: var(--space-3);
	}

	.feature-card {
		display: flex;
		align-items: flex-start;
		gap: var(--space-3);
		background: var(--surface);
		border: 1px solid var(--border-light);
		border-radius: var(--radius-lg);
		padding: var(--space-4);
		transition: border-color var(--transition-fast);
	}

	.feature-card:hover {
		border-color: var(--border);
	}

	.feature-icon {
		width: 36px;
		height: 36px;
		border-radius: var(--radius-lg);
		background: var(--primary-50);
		color: var(--primary);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.feature-title {
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--text-primary);
		margin: 0 0 var(--space-1);
	}

	.feature-desc {
		font-size: 0.8125rem;
		color: var(--text-muted);
		margin: 0;
	}

	.tech-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		background: var(--surface);
		border: 1px solid var(--border-light);
		border-radius: var(--radius-lg);
		padding: var(--space-4);
	}

	.tech-item {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		font-size: 0.9375rem;
	}

	.tech-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--primary);
		flex-shrink: 0;
	}

	.tech-name {
		font-weight: 600;
		color: var(--text-primary);
	}

	.tech-desc {
		color: var(--text-muted);
	}

	.links-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	.link-item {
		display: flex;
		align-items: center;
		gap: var(--space-3);
		background: var(--surface);
		border: 1px solid var(--border-light);
		border-radius: var(--radius-lg);
		padding: var(--space-3) var(--space-4);
		color: var(--text-primary);
		text-decoration: none;
		font-size: 0.9375rem;
		font-weight: 500;
		transition: all var(--transition-fast);
	}

	.link-item:hover {
		border-color: var(--primary);
		color: var(--primary);
	}

	@@media (max-width: 640px) {
		.about-hero {
			flex-direction: column;
			text-align: center;
		}

		.feature-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
