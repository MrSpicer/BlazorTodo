@page "/"
@implements IDisposable
@inject ITodoService TodoService
@inject IProjectService ProjectService
@inject INoteService NoteService
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

<PageTitle>BlazorTodo - Todo Management</PageTitle>

@if (!ProjectService.Projects.Any())
{
    <div class="welcome-screen">
        <div class="welcome-content">
            <div class="welcome-icon">
                <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                    <path d="M22 4L12 14.01l-3-3"/>
                </svg>
            </div>
            <h1 class="welcome-title">Welcome to BlazorTodo</h1>
            <p class="welcome-description">
                Get started by creating your first project. Projects help you organize your tasks 
                and stay focused on what matters most.
            </p>
            <button class="btn btn-primary btn-lg" @onclick="ShowProjectModal">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M12 5v14M5 12h14"/>
                </svg>
                Create Your First Project
            </button>
            <button class="btn btn-outline-secondary btn-lg" @onclick='() => NavigationManager.NavigateTo("/settings")'>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M3 12a9 9 0 0 1 15-6.7L21 8"/>
                    <path d="M21 22v-6h-6"/>
                    <path d="M21 12a9 9 0 0 1-15 6.7L3 16"/>
                </svg>
                Restore from Another Device
            </button>
        </div>
    </div>
}
else
{
    <!-- Project Tabs -->
    <ProjectTabs Projects="@ProjectService.Projects"
                 SelectedProject="@ProjectService.SelectedProject"
                 Todos="@TodoService.Todos"
                 OnProjectSelected="HandleProjectSelected"
                 OnNewProjectClick="ShowProjectModal"
                 OnDeleteProject="HandleDeleteProject" />

    <!-- Stats Dashboard -->
    <div class="stats-dashboard" aria-live="polite" aria-label="Task statistics">
        <div class="stat-card">
            <div class="stat-icon total">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <path d="M3 9h18"/>
                </svg>
            </div>
            <div class="stat-info">
                <span class="stat-value">@GetProjectTodoCount()</span>
                <span class="stat-label">Total Tasks</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon pending">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M12 6v6l4 2"/>
                </svg>
            </div>
            <div class="stat-info">
                <span class="stat-value">@TodoService.GetActiveCount(ProjectService.SelectedProject?.Id)</span>
                <span class="stat-label">Remaining</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon completed">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                    <path d="M22 4L12 14.01l-3-3"/>
                </svg>
            </div>
            <div class="stat-info">
                <span class="stat-value">@GetCompletedCount()</span>
                <span class="stat-label">Completed</span>
            </div>
        </div>
        <div class="stat-card progress-card">
            <div class="progress-info">
                <span class="progress-label">Progress</span>
                <span class="progress-value">@GetProgressPercentage()%</span>
            </div>
            <div class="progress-bar-container">
                <div class="progress-bar" style="width: @GetProgressPercentage()%"></div>
            </div>
        </div>
    </div>

    <!-- Content Tabs -->
    <div class="content-tabs">
        <button class="content-tab @(_activeTab == "tasks" ? "active" : "")"
                @onclick='() => _activeTab = "tasks"'>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M9 12l2 2 4-4"/>
            </svg>
            Tasks
            <span class="tab-count">@GetProjectTodoCount()</span>
        </button>
        <button class="content-tab @(_activeTab == "notes" ? "active" : "")"
                @onclick='() => _activeTab = "notes"'>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
            </svg>
            Notes
            <span class="tab-count">@GetProjectNoteCount()</span>
        </button>
    </div>

    @if (_activeTab == "tasks")
    {
        <!-- Action Bar -->
        <div class="action-bar">
            <div class="action-bar-left">
                <button class="btn btn-primary" @onclick="ShowTodoModal">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M12 5v14M5 12h14"/>
                    </svg>
                    Add Task
                </button>
            </div>
            <div class="action-bar-right">
                @if (GetProjectTodoCount() > 0)
                {
                    <button class="btn btn-ghost danger" @onclick="HandleClearAll">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                        </svg>
                        Clear All
                    </button>
                }
            </div>
        </div>

        <!-- Filters -->
        <TodoFilters FilterCriteria="@_filterCriteria"
                     TotalCount="@GetProjectTodoCount()"
                     FilteredCount="@GetFilteredTodos().Count()"
                     FilterChanged="StateHasChanged" />

        <!-- Todo List -->
        <TodoListView Items="@GetFilteredTodos()"
                      OnEdit="HandleEdit"
                      OnDelete="HandleDelete"
                      OnSave="HandleSave" />
    }
    else
    {
        <!-- Notes Action Bar -->
        <div class="action-bar">
            <div class="action-bar-left">
                <button class="btn btn-primary" @onclick="ShowNoteModal">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M12 5v14M5 12h14"/>
                    </svg>
                    Add Note
                </button>
            </div>
        </div>

        <!-- Notes List -->
        <NotesList Items="@GetProjectNotes()"
                   OnEdit="HandleNoteEdit"
                   OnDelete="HandleNoteDelete" />
    }
}

<!-- Modals -->
<ProjectModal IsVisible="@_showProjectModal"
              IsEditing="false"
              OnClose="HideProjectModal"
              OnSave="HandleSaveProject" />

<TodoFormModal IsVisible="@_showTodoModal"
               IsEditing="@_isEditing"
               EditingTodo="@_currentTodo"
               DefaultProjectId="@ProjectService.SelectedProject?.Id"
               OnClose="HideTodoModal"
               OnSubmit="HandleFormSubmit" />

<NoteFormModal IsVisible="@_showNoteModal"
               IsEditing="@_isEditingNote"
               EditingNote="@_currentNote"
               DefaultProjectId="@ProjectService.SelectedProject?.Id"
               OnClose="HideNoteModal"
               OnSubmit="HandleNoteFormSubmit" />

<style>
    /* Welcome Screen */
    .welcome-screen {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
    }
    
    .welcome-content {
        text-align: center;
        max-width: 480px;
        padding: var(--space-8);
    }
    
    .welcome-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 120px;
        height: 120px;
        background: linear-gradient(135deg, var(--primary-50) 0%, var(--primary-light) 100%);
        border-radius: var(--radius-full);
        color: var(--primary);
        margin-bottom: var(--space-6);
    }
    
    .welcome-title {
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0 0 var(--space-4);
    }
    
    .welcome-description {
        font-size: 1.0625rem;
        color: var(--text-secondary);
        line-height: 1.6;
        margin: 0 0 var(--space-6);
    }
    
    /* Stats Dashboard */
    .stats-dashboard {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: var(--space-4);
        margin-bottom: var(--space-5);
    }
    
    .stat-card {
        background: var(--surface);
        border: 1px solid var(--border-light);
        border-radius: var(--radius-lg);
        padding: var(--space-4);
        display: flex;
        align-items: center;
        gap: var(--space-3);
        transition: all var(--transition-fast);
    }
    
    .stat-card:hover {
        border-color: var(--border);
        box-shadow: var(--shadow-sm);
    }
    
    .stat-icon {
        width: 44px;
        height: 44px;
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    
    .stat-icon.total {
        background: var(--primary-50);
        color: var(--primary);
    }
    
    .stat-icon.pending {
        background: var(--warning-light);
        color: #d97706;
    }
    
    .stat-icon.completed {
        background: var(--success-light);
        color: var(--success);
    }
    
    .stat-info {
        display: flex;
        flex-direction: column;
    }
    
    .stat-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-primary);
        line-height: 1;
    }
    
    .stat-label {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-top: var(--space-1);
    }
    
    .progress-card {
        flex-direction: column;
        align-items: stretch;
        gap: var(--space-2);
    }
    
    .progress-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .progress-label {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text-secondary);
    }
    
    .progress-value {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--primary);
    }
    
    .progress-bar-container {
        height: 8px;
        background: var(--gray-200);
        border-radius: var(--radius-full);
        overflow: hidden;
    }
    
    .progress-bar {
        height: 100%;
        background: linear-gradient(90deg, var(--primary) 0%, var(--success) 100%);
        border-radius: var(--radius-full);
        transition: width 0.5s ease;
        min-width: 4px;
    }
    
    /* Content Tabs */
    .content-tabs {
        display: flex;
        gap: var(--space-1);
        border-bottom: 2px solid var(--border-light);
        margin-bottom: var(--space-5);
    }

    .content-tab {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-3) var(--space-4);
        background: transparent;
        border: none;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        font-size: 0.9375rem;
        font-weight: 500;
        color: var(--text-secondary);
        cursor: pointer;
        transition: all var(--transition-fast);
        border-radius: var(--radius-md) var(--radius-md) 0 0;
    }

    .content-tab:hover {
        color: var(--text-primary);
        background: var(--gray-50);
    }

    .content-tab.active {
        color: var(--primary);
        border-bottom-color: var(--primary);
    }

    .tab-count {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 20px;
        height: 20px;
        padding: 0 var(--space-1);
        background: var(--gray-100);
        border-radius: var(--radius-full);
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--text-muted);
    }

    .content-tab.active .tab-count {
        background: var(--primary-50);
        color: var(--primary);
    }

    /* Action Bar */
    .action-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: var(--space-5);
        flex-wrap: wrap;
        gap: var(--space-3);
    }
    
    .action-bar-left, .action-bar-right {
        display: flex;
        align-items: center;
        gap: var(--space-2);
    }
    
    .btn-ghost.danger {
        color: var(--danger);
    }
    
    .btn-ghost.danger:hover {
        background: var(--danger-light);
    }
    
    @@media (max-width: 640px) {
        .stats-dashboard {
            grid-template-columns: repeat(2, 1fr);
        }
        
        .action-bar {
            flex-direction: column;
            align-items: stretch;
        }
        
        .action-bar-left, .action-bar-right {
            justify-content: center;
        }
    }
</style>

@code {
    private TodoItem _currentTodo = new();
    private bool _isEditing;
    private TodoFilterCriteria _filterCriteria = new();
    private bool _initialized;
    private bool _showProjectModal;
    private bool _showTodoModal;

    private string _activeTab = "tasks";
    private ProjectNote _currentNote = new();
    private bool _isEditingNote;
    private bool _showNoteModal;

    protected override void OnInitialized()
    {
        TodoService.OnTodosChanged += StateHasChanged;
        ProjectService.OnProjectsChanged += StateHasChanged;
        NoteService.OnNotesChanged += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            await ProjectService.InitializeAsync();
            await TodoService.InitializeAsync();
            await NoteService.InitializeAsync();
            StateHasChanged();
        }
    }

    private IEnumerable<TodoItem> GetFilteredTodos() =>
        TodoService.GetFilteredAndSorted(_filterCriteria, ProjectService.SelectedProject?.Id);

    private IReadOnlyList<ProjectNote> GetProjectNotes() =>
        NoteService.GetNotesForProject(ProjectService.SelectedProject?.Id ?? Guid.Empty);

    private int GetProjectNoteCount() =>
        ProjectService.SelectedProject == null ? 0
        : NoteService.Notes.Count(n => n.ProjectId == ProjectService.SelectedProject.Id);

    private int GetProjectTodoCount()
    {
        var projectId = ProjectService.SelectedProject?.Id;
        return projectId.HasValue 
            ? TodoService.Todos.Count(t => t.ProjectId == projectId.Value)
            : TodoService.Todos.Count;
    }
    
    private int GetCompletedCount()
    {
        var projectId = ProjectService.SelectedProject?.Id;
        return projectId.HasValue 
            ? TodoService.Todos.Count(t => t.ProjectId == projectId.Value && t.Status == TodoItemStatus.Done)
            : TodoService.Todos.Count(t => t.Status == TodoItemStatus.Done);
    }
    
    private int GetProgressPercentage()
    {
        var total = GetProjectTodoCount();
        if (total == 0) return 0;
        return (int)((GetCompletedCount() / (double)total) * 100);
    }

    private async Task HandleFormSubmit(TodoItem todo)
    {
        if (todo.ProjectId == Guid.Empty && ProjectService.SelectedProject != null)
        {
            todo.ProjectId = ProjectService.SelectedProject.Id;
        }
        await TodoService.SaveTodoAsync(todo);
        HideTodoModal();
        ResetForm();
    }

    private void HandleFormCancel()
    {
        HideTodoModal();
        ResetForm();
    }

    private void HandleEdit(TodoItem todo)
    {
        _currentTodo = todo;
        _isEditing = true;
        ShowTodoModal();
    }

    private async Task HandleDelete(TodoItem todo)
    {
        if (await DialogService.ConfirmAsync($"Delete '{todo.Title}'?"))
            await TodoService.DeleteTodoAsync(todo);
    }

    private async Task HandleSave(TodoItem todo)
    {
        await TodoService.SaveTodoAsync(todo);
    }

    private async Task HandleClearAll()
    {
        var projectName = ProjectService.SelectedProject?.Name ?? "all projects";
        if (await DialogService.ConfirmAsync($"Delete ALL todos in '{projectName}'? This cannot be undone."))
        {
            await TodoService.ClearAllAsync(ProjectService.SelectedProject?.Id);
            ResetForm();
        }
    }

    private void ResetForm()
    {
        _currentTodo = new TodoItem();
        if (ProjectService.SelectedProject != null)
        {
            _currentTodo.ProjectId = ProjectService.SelectedProject.Id;
        }
        _isEditing = false;
    }

    private void ShowProjectModal() => _showProjectModal = true;
    private void HideProjectModal() => _showProjectModal = false;
    private void ShowTodoModal() => _showTodoModal = true;
    private void HideTodoModal()
    {
        _showTodoModal = false;
        _isEditing = false;
    }

    private void HandleProjectSelected(Project project)
    {
        ProjectService.SelectProject(project);
        ResetForm();
    }

    private async Task HandleSaveProject(Project project)
    {
        await ProjectService.SaveProjectAsync(project);
        ProjectService.SelectProject(project);
        ResetForm();
    }

    private async Task HandleDeleteProject(Project project)
    {
        if (await DialogService.ConfirmAsync($"Delete project '{project.Name}' and all its todos? This cannot be undone."))
        {
            await TodoService.DeleteTodosByProjectAsync(project.Id);
            await NoteService.DeleteNotesByProjectAsync(project.Id);
            await ProjectService.DeleteProjectAsync(project);
        }
    }

    private void HandleNoteEdit(ProjectNote note)
    {
        _currentNote = note;
        _isEditingNote = true;
        ShowNoteModal();
    }

    private async Task HandleNoteDelete(ProjectNote note)
    {
        if (await DialogService.ConfirmAsync($"Delete note '{note.Title}'?"))
            await NoteService.DeleteNoteAsync(note);
    }

    private async Task HandleNoteFormSubmit(ProjectNote note)
    {
        if (note.ProjectId == Guid.Empty && ProjectService.SelectedProject != null)
        {
            note.ProjectId = ProjectService.SelectedProject.Id;
        }
        await NoteService.SaveNoteAsync(note);
        HideNoteModal();
        ResetNoteForm();
    }

    private void ResetNoteForm()
    {
        _currentNote = new ProjectNote();
        if (ProjectService.SelectedProject != null)
        {
            _currentNote.ProjectId = ProjectService.SelectedProject.Id;
        }
        _isEditingNote = false;
    }

    private void ShowNoteModal() => _showNoteModal = true;
    private void HideNoteModal()
    {
        _showNoteModal = false;
        _isEditingNote = false;
    }

    public void Dispose()
    {
        TodoService.OnTodosChanged -= StateHasChanged;
        ProjectService.OnProjectsChanged -= StateHasChanged;
        NoteService.OnNotesChanged -= StateHasChanged;
    }
}
