<div class="sidebar-header">
    <button class="collapse-btn" @onclick="OnToggleSidebar" title="@(IsCollapsed ? "Expand" : "Collapse")" aria-label="@(IsCollapsed ? "Expand sidebar" : "Collapse sidebar")">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            @if (IsCollapsed)
            {
                <polyline points="9 18 15 12 9 6"/>
            }
            else
            {
                <polyline points="15 18 9 12 15 6"/>
            }
        </svg>
    </button>
</div>

<nav class="sidebar-nav">
    <NavLink class="nav-link" href="" Match="NavLinkMatch.All" title="My Todos">
        <span class="nav-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M9 11l3 3L22 4"/>
                <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
            </svg>
        </span>
        @if (!IsCollapsed)
        {
            <span class="nav-text">My Todos</span>
        }
    </NavLink>
    <NavLink class="nav-link" href="statistics" title="Statistics">
        <span class="nav-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <line x1="18" y1="20" x2="18" y2="10"/>
                <line x1="12" y1="20" x2="12" y2="4"/>
                <line x1="6" y1="20" x2="6" y2="14"/>
            </svg>
        </span>
        @if (!IsCollapsed)
        {
            <span class="nav-text">Statistics</span>
        }
    </NavLink>
    <NavLink class="nav-link" href="settings" title="Settings">
        <span class="nav-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="3"/>
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
            </svg>
        </span>
        @if (!IsCollapsed)
        {
            <span class="nav-text">Settings</span>
        }
    </NavLink>
    <NavLink class="nav-link" href="about" title="About">
        <span class="nav-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12.01" y2="8"/>
                <line x1="12" y1="12" x2="12" y2="16"/>
            </svg>
        </span>
        @if (!IsCollapsed)
        {
            <span class="nav-text">About</span>
        }
    </NavLink>
</nav>

@code {
    [Parameter]
    public bool IsCollapsed { get; set; }

    [Parameter]
    public EventCallback OnToggleSidebar { get; set; }
}
